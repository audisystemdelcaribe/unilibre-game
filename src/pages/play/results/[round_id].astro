---
import PlayLayout from "../../../layouts/PlayLayout.astro";
import { Icon } from 'astro-icon/components';
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { round_id } = Astro.params;
const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

// 1. Obtener datos de la ronda y el jugador
const { data: player } = await Astro.locals.supabase
    .from('players').select('id, name').eq('auth_user_id', user.id).single();

const { data: round } = await Astro.locals.supabase
    .from('event_rounds').select('*, events(name, game_mode_id)').eq('id', round_id).single();

if (!round || !player) return Astro.redirect("/play");

// 2. Obtener el puntaje y tiempo del alumno en este evento (debe haber participado)
const { data: myStats } = await Astro.locals.supabase
    .from('event_players')
    .select('score, total_time_ms, classroom_group_id, is_finalist')
    .eq('event_id', round.event_id)
    .eq('player_id', player.id)
    .single();

if (!myStats) return Astro.redirect("/play?error=no_participaste");

// 3. Para Clásico: nivel alcanzado (última respuesta en game_answers)
let levelReached: { difficulty_order: number; name: string } | null = null;
if (round?.events?.game_mode_id === 2) {
    const { data: lastAnswer } = await supabaseAdmin
        .from('game_answers')
        .select('question_id')
        .eq('round_id', round_id)
        .eq('player_id', player.id)
        .order('id', { ascending: false })
        .limit(1)
        .maybeSingle();
    if (lastAnswer?.question_id) {
        const { data: q } = await supabaseAdmin.from('questions').select('level_id').eq('id', lastAnswer.question_id).single();
        if (q?.level_id) {
            const { data: lvl } = await supabaseAdmin.from('game_levels').select('difficulty_order, name').eq('id', q.level_id).single();
            if (lvl) levelReached = { difficulty_order: lvl.difficulty_order, name: lvl.name || `Nivel ${lvl.difficulty_order}` };
        }
    }
}

// 4. Ranking completo (solo para preselección)
const { data: fullRanking } = await Astro.locals.supabase
    .from('event_players')
    .select('player_id, score, total_time_ms, players(name)')
    .eq('event_id', round.event_id)
    .eq('classroom_group_id', myStats.classroom_group_id)
    .order('score', { ascending: false })
    .order('total_time_ms', { ascending: true })
    .order('player_id', { ascending: true });

const myRank = (fullRanking || []).findIndex((r: any) => r.player_id === player.id) + 1 || 1;
const top3 = (fullRanking || []).slice(0, 3);
const isClasico = round?.events?.game_mode_id === 2;
const score = myStats?.score ?? 0;
const isFullWinner = isClasico && score > 0 && (levelReached?.difficulty_order ?? 0) >= 15;
---

<PlayLayout title="Resultados Finales">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>
    <div class="flex flex-col items-center justify-center min-h-screen p-6 bg-gradient-to-b from-zinc-950 to-zinc-900 text-white font-sans text-center">

        <div class="w-full max-w-md animate-in fade-in zoom-in duration-700">
            {isClasico ? (
                /* Juego Final (Clásico / Silla Caliente): sin ranking, nombre, nivel, ganancia, felicitación */
                <>
                    {isFullWinner ? (
                        /* Ganador nivel 15: celebración elaborada */
                        <div class="w-full max-w-lg text-center">
                            <div class="mb-6 animate-pulse">
                                <div class="w-36 h-36 rounded-full mx-auto flex items-center justify-center bg-gradient-to-br from-yellow-400 via-amber-500 to-orange-600 shadow-2xl shadow-yellow-500/50 ring-4 ring-yellow-300/50">
                                    <Icon name="lucide:trophy" class="w-20 h-20 text-white drop-shadow-lg" />
                                </div>
                            </div>
                            <h1 class="text-5xl md:text-6xl font-black italic uppercase tracking-tighter mb-2 bg-gradient-to-r from-yellow-300 via-amber-400 to-orange-500 bg-clip-text text-transparent animate-pulse">
                                ¡GANADOR!
                            </h1>
                            <p class="text-zinc-400 font-bold text-lg mb-6">{player.name}</p>
                            <p class="text-zinc-500 font-bold uppercase text-[10px] tracking-[0.3em] mb-8">{round.events?.name}</p>
                            <div class="bg-gradient-to-br from-yellow-500/20 to-orange-500/20 border-2 border-yellow-500/50 p-8 rounded-[3rem] shadow-2xl mb-8">
                                <p class="text-yellow-400/90 font-bold uppercase text-xs mb-2 tracking-widest">Premio final</p>
                                <h2 class="text-5xl font-black text-yellow-300 italic mb-4 tabular-nums">
                                    ${new Intl.NumberFormat('es-CO', { maximumFractionDigits: 0 }).format(score)}
                                </h2>
                                <p class="text-zinc-400 text-sm">Llegaste al nivel {levelReached?.difficulty_order ?? 15} y respondiste correctamente.</p>
                            </div>
                        </div>
                    ) : (
                        /* Participación normal: nombre, nivel, ganancia o $0, felicitación */
                        <>
                            <div class="relative mb-6 inline-block">
                                <div class:list={[
                                    "w-28 h-28 rounded-full flex items-center justify-center shadow-2xl transition-all duration-1000",
                                    score > 0 ? "bg-yellow-500/80 shadow-yellow-500/20" : "bg-zinc-800 shadow-black/50"
                                ]}>
                                    <Icon name={score > 0 ? "lucide:trophy" : "lucide:hand-heart"} class="w-14 h-14 text-white" />
                                </div>
                            </div>
                            <h1 class="text-3xl font-black italic uppercase tracking-tighter mb-1">¡Juego Terminado!</h1>
                            <p class="text-xl font-bold text-zinc-300 mb-2">{player.name}</p>
                            <p class="text-zinc-500 font-bold uppercase text-[10px] tracking-[0.3em] mb-8">{round.events?.name}</p>
                            <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-[3rem] shadow-2xl mb-8 w-full max-w-md">
                                {score > 0 ? (
                                    <>
                                        <p class="text-zinc-500 font-bold uppercase text-xs mb-1 tracking-widest">Ganaste</p>
                                        <h2 class="text-4xl font-black text-yellow-400 italic mb-3 tabular-nums">
                                            ${new Intl.NumberFormat('es-CO', { maximumFractionDigits: 0 }).format(score)}
                                        </h2>
                                        <p class="text-zinc-400 text-sm mb-2">Llegaste hasta el nivel {levelReached?.difficulty_order ?? '—'} ({levelReached?.name ?? '—'})</p>
                                        <p class="text-zinc-500 text-sm">¡Felicitaciones por participar!</p>
                                    </>
                                ) : (
                                    <>
                                        <p class="text-zinc-500 font-bold uppercase text-xs mb-1 tracking-widest">No alcanzaste un seguro</p>
                                        <h2 class="text-3xl font-black text-zinc-400 italic mb-3">$0</h2>
                                        <p class="text-zinc-400 text-sm mb-2">Llegaste hasta el nivel {levelReached?.difficulty_order ?? '—'} ({levelReached?.name ?? '—'})</p>
                                        <p class="text-zinc-500 text-sm">¡Gracias por participar! Sigue intentando.</p>
                                    </>
                                )}
                            </div>
                        </>
                    )}
                    <a href="/dashboard" class="btn btn-primary btn-wide rounded-2xl font-black italic uppercase tracking-widest shadow-xl">
                        Volver al Panel
                    </a>
                </>
            ) : (
                /* Preselección: ranking y podio */
                <>
                    <div class="relative mb-8 inline-block">
                        <div class:list={[
                            "w-32 h-32 rounded-full flex items-center justify-center shadow-2xl transition-all duration-1000",
                            myRank === 1 ? "bg-yellow-500 shadow-yellow-500/20" : "bg-zinc-800 shadow-black/50"
                        ]}>
                            <Icon name={myRank === 1 ? "lucide:trophy" : "lucide:medal"} class="w-16 h-16 text-white" />
                        </div>
                        <div class="absolute -bottom-2 -right-2 bg-primary text-white font-black px-4 py-1 rounded-full text-xl shadow-lg border-4 border-zinc-950">
                            #{myRank}
                        </div>
                    </div>

                    <h1 class="text-4xl font-black italic uppercase tracking-tighter mb-2">¡Juego Terminado!</h1>
                    <p class="text-zinc-500 font-bold uppercase text-[10px] tracking-[0.3em] mb-10">{round.events?.name}</p>

                    <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-[3rem] shadow-2xl mb-8 relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></div>
                        <p class="text-zinc-500 font-bold uppercase text-xs mb-2 tracking-widest">Puntaje Total</p>
                        <h2 class="text-6xl font-black text-primary italic mb-6 tabular-nums">{myStats?.score || 0}</h2>
                        {myStats?.is_finalist && (
                            <div class="mb-4 p-3 bg-yellow-500/20 border border-yellow-500/50 rounded-2xl">
                                <p class="text-yellow-400 font-black uppercase text-xs tracking-wider">🏆 ¡Eres finalista! Puedes participar en la Gran Final.</p>
                            </div>
                        )}
                        <div class="grid grid-cols-2 gap-4 border-t border-zinc-800 pt-6">
                            <div class="text-left">
                                <p class="text-[9px] font-black text-zinc-600 uppercase mb-1">Tu Salón</p>
                                <p class="text-sm font-bold text-zinc-300">{myStats.classroom_group_id}</p>
                            </div>
                            <div class="text-right">
                                <p class="text-[9px] font-black text-zinc-600 uppercase mb-1">Tiempo total</p>
                                <p class="text-sm font-bold text-zinc-300 font-mono">{(myStats?.total_time_ms ?? 0) / 1000}s</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-black/20 rounded-3xl p-6 border border-white/5 mb-10">
                        <h4 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4">Top 3 del Salón</h4>
                        <div class="space-y-3">
                            {top3?.map((item: any, idx: number) => (
                                <div class="flex justify-between items-center text-sm">
                                    <div class="flex items-center gap-3">
                                        <span class="w-6 h-6 rounded-lg bg-zinc-800 flex items-center justify-center font-bold text-[10px]">{idx + 1}</span>
                                        <span class:list={["font-bold", item.players?.name === player.name ? "text-primary" : "text-zinc-400"]}>
                                            {item.players?.name} {item.players?.name === player.name ? "(Tú)" : ""}
                                        </span>
                                    </div>
                                    <div class="text-right">
                                        <span class="font-black font-mono text-zinc-500 block">{item.score}</span>
                                        <span class="text-[10px] text-zinc-600 font-mono">{(item.total_time_ms ?? 0) / 1000}s</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <a href="/dashboard" class="btn btn-primary btn-wide rounded-2xl font-black italic uppercase tracking-widest shadow-xl">
                        Volver al Panel
                    </a>
                </>
            )}
        </div>
    </div>

    <script is:inline define:vars={{ myRank, isClasico, score, isFullWinner }}>
        const wonMoney = isClasico ? score > 0 : myRank === 1;
        if (wonMoney) {
            if (isFullWinner) {
                const duration = 4000;
                const end = Date.now() + duration;
                (function frame() {
                    confetti({
                        particleCount: 4,
                        angle: 60,
                        spread: 55,
                        origin: { x: 0 },
                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d']
                    });
                    confetti({
                        particleCount: 4,
                        angle: 120,
                        spread: 55,
                        origin: { x: 1 },
                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d']
                    });
                    if (Date.now() < end) requestAnimationFrame(frame);
                }());
                setTimeout(function() {
                    confetti({
                        particleCount: 100,
                        spread: 100,
                        origin: { y: 0.5 },
                        colors: ['#fbbf24', '#f59e0b', '#f97316', '#ea580c', '#fcd34d', '#ffffff']
                    });
                }, 500);
            } else {
                confetti({
                    particleCount: 120,
                    spread: 70,
                    origin: { y: 0.6 },
                    colors: ['#fbbf24', '#f59e0b', '#f97316']
                });
            }
        }
    </script>
</PlayLayout>