---
import PlayLayout from "../../../layouts/PlayLayout.astro";
import { Icon } from 'astro-icon/components';

const { round_id } = Astro.params;
const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

// 1. Obtener datos de la ronda y el jugador
const { data: player } = await Astro.locals.supabase
    .from('players').select('id, name').eq('auth_user_id', user.id).single();

const { data: round } = await Astro.locals.supabase
    .from('event_rounds').select('*, events(name)').eq('id', round_id).single();

// 2. Obtener el puntaje del alumno en este evento
const { data: myStats } = await Astro.locals.supabase
    .from('event_players')
    .select('score, classroom_group_id')
    .eq('event_id', round.event_id)
    .eq('player_id', player.id)
    .single();

// 3. CALCULAR POSICIÓN (Ranking)
// Contamos cuántos estudiantes del mismo grupo tienen más puntos que yo
const { count: playersAbove } = await Astro.locals.supabase
    .from('event_players')
    .select('*', { count: 'exact', head: true })
    .eq('event_id', round.event_id)
    .eq('classroom_group_id', myStats.classroom_group_id)
    .gt('score', myStats.score || 0);

const myRank = (playersAbove || 0) + 1;

// 4. Obtener el Top 3 del salón para comparar
const { data: top3 } = await Astro.locals.supabase
    .from('event_players')
    .select('score, players(name)')
    .eq('event_id', round.event_id)
    .eq('classroom_group_id', myStats.classroom_group_id)
    .order('score', { ascending: false })
    .limit(3);
---

<PlayLayout title="Resultados Finales">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>
    <div class="flex flex-col items-center justify-center min-h-screen p-6 bg-gradient-to-b from-zinc-950 to-zinc-900 text-white font-sans text-center">

        <div class="w-full max-w-md animate-in fade-in zoom-in duration-700">
            <!-- ICONO DE TROFEO O MEDALLA -->
            <div class="relative mb-8 inline-block">
                <div class:list={[
                    "w-32 h-32 rounded-full flex items-center justify-center shadow-2xl transition-all duration-1000",
                    myRank === 1 ? "bg-yellow-500 shadow-yellow-500/20" : "bg-zinc-800 shadow-black/50"
                ]}>
                    <Icon name={myRank === 1 ? "lucide:trophy" : "lucide:medal"} class="w-16 h-16 text-white" />
                </div>
                <div class="absolute -bottom-2 -right-2 bg-primary text-white font-black px-4 py-1 rounded-full text-xl shadow-lg border-4 border-zinc-950">
                    #{myRank}
                </div>
            </div>

            <h1 class="text-4xl font-black italic uppercase tracking-tighter mb-2">¡Juego Terminado!</h1>
            <p class="text-zinc-500 font-bold uppercase text-[10px] tracking-[0.3em] mb-10">{round.events?.name}</p>

            <!-- CARD DE PUNTUACIÓN -->
            <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-[3rem] shadow-2xl mb-8 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></div>

                <p class="text-zinc-500 font-bold uppercase text-xs mb-2 tracking-widest">Puntaje Total</p>
                <h2 class="text-6xl font-black text-primary italic mb-6 tabular-nums">{myStats?.score || 0}</h2>

                <div class="grid grid-cols-2 gap-4 border-t border-zinc-800 pt-6">
                    <div class="text-left">
                        <p class="text-[9px] font-black text-zinc-600 uppercase mb-1">Tu Salón</p>
                        <p class="text-sm font-bold text-zinc-300">{myStats.classroom_group_id}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[9px] font-black text-zinc-600 uppercase mb-1">Estatus</p>
                        <p class="text-sm font-bold text-green-500 uppercase italic">Completado</p>
                    </div>
                </div>
            </div>

            <!-- MINI PODIO -->
            <div class="bg-black/20 rounded-3xl p-6 border border-white/5 mb-10">
                <h4 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4">Top 3 del Salón</h4>
                <div class="space-y-3">
                    {top3?.map((item: any, idx: number) => (
                            <div class="flex justify-between items-center text-sm">
                                <div class="flex items-center gap-3">
                                    <span class="w-6 h-6 rounded-lg bg-zinc-800 flex items-center justify-center font-bold text-[10px]">{idx + 1}</span>
                                    <span class:list={["font-bold", item.players?.name === player.name ? "text-primary" : "text-zinc-400"]}>
                                    {item.players?.name} {item.players?.name === player.name ? "(Tú)" : ""}
                                </span>
                                </div>
                                <span class="font-black font-mono text-zinc-500">{item.score}</span>
                            </div>
                    ))}
                </div>
            </div>

            <a href="/dashboard" class="btn btn-primary btn-wide rounded-2xl font-black italic uppercase tracking-widest shadow-xl">
                Volver al Panel
            </a>
        </div>
    </div>

    <script is:inline define:vars={{ myRank }}>
        if (myRank === 1) {
            confetti({
                particleCount: 150,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#ff0000', '#00ff00', '#0000ff', '#ffff00']
            });
        }
    </script>
</PlayLayout>