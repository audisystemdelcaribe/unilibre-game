---
import PlayLayout from "../../layouts/PlayLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";

const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

const { data: player } = await Astro.locals.supabase
    .from('players')
    .select('id')
    .eq('auth_user_id', user.id)
    .single();

if (!player) return Astro.redirect("/");

// Buscar si el jugador es concursante activo en un evento Clásico (Silla Caliente)
const { data: acList } = await supabaseAdmin
    .from('active_contestants')
    .select('round_id, event_id')
    .eq('player_id', player.id);

const { data: clasicoEvent } = acList?.length
    ? await supabaseAdmin
        .from('events')
        .select('id')
        .eq('game_mode_id', 2)
        .in('id', acList.map((a) => a.event_id))
        .limit(1)
        .maybeSingle()
    : { data: null };

const clasicoEntry = clasicoEvent && acList?.length
    ? acList.find((a) => a.event_id === clasicoEvent.id)
    : null;

if (clasicoEntry?.round_id) {
    const { data: round } = await supabaseAdmin
        .from('event_rounds')
        .select('status')
        .eq('id', clasicoEntry.round_id)
        .single();

    if (round?.status === 'waiting' || round?.status === 'active') {
        return Astro.redirect(`/play/waiting/${clasicoEntry.round_id}`);
    }
}
---

<PlayLayout title="Silla Caliente">
    <div class="min-h-screen flex flex-col items-center justify-center p-6 bg-zinc-950 text-white text-center">
        <h1 class="text-3xl font-black italic uppercase mb-4">Silla Caliente</h1>
        <p class="text-zinc-400 max-w-md">
            {clasicoEntry
                ? "La Silla Caliente aún no está lista. Espera a que el docente abra la ronda."
                : "No tienes acceso a Silla Caliente. Solo el ganador de Mente más Rápida puede entrar."}
        </p>
        <a href="/play" class="btn btn-primary mt-8">Volver a Unirse</a>
    </div>
</PlayLayout>
