---
import PlayLayout from "../../../layouts/PlayLayout.astro";
import { actions } from "astro:actions";
import { Icon } from 'astro-icon/components';

const { round_id } = Astro.params;
const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");

// 1. Obtener datos de la Ronda y Pregunta actual
const { data: round } = await Astro.locals.supabase
    .from('event_rounds')
    .select('*, events(name, program_id), questions(*, game_levels(points, time_limit), answers(*))')
    .eq('id', round_id)
    .single();

if (!round || round.status !== 'active') return Astro.redirect(`/play/waiting/${round_id}`);

// 2. Obtener / Crear Sesión (Plan de rescate incluido)
const { data: player } = await Astro.locals.supabase
    .from('players').select('id, name').eq('auth_user_id', user.id).single();

let { data: gameSession } = await Astro.locals.supabase
    .from('game_sessions')
    .select('id, score')
    .eq('player_id', player?.id)
    .eq('event_id', round.event_id)
    .eq('finished', false)
    .maybeSingle();

if (!gameSession && player) {
    const { data: newS } = await Astro.locals.supabase.from('game_sessions')
        .insert([{ player_id: player.id, event_id: round.event_id, round_id: round.id, session_type: 'classroom' }])
        .select().single();
    gameSession = newS;
}

// 3. Resultado de la acción (Feedback)
const result = Astro.getActionResult(actions.submitAnswer);
const hasResponded = result?.data?.success || false;
const isCorrect = result?.data?.correct || false;
---

<PlayLayout title="¡Carrera en Vivo!">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>

    <div class="flex flex-col h-screen p-4 bg-zinc-950 text-white overflow-hidden font-sans">

        <!-- HEADER: SCORE ACTUAL -->
        <header class="flex justify-between items-center bg-zinc-900 border border-zinc-800 p-4 rounded-[2rem] mb-6 shadow-2xl">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center font-black text-white italic">
                    {player?.name?.charAt(0).toUpperCase()}
                </div>
                <div>
                    <p class="text-[8px] font-black text-zinc-500 uppercase tracking-widest leading-none mb-1">Puntos Totales</p>
                    <p class="text-xl font-black text-primary leading-none tabular-nums">{gameSession?.score || 0}</p>
                </div>
            </div>
            <div id="timer-display" class="text-4xl font-black italic text-white tabular-nums">00</div>
        </header>

        <main class="flex-1 flex flex-col justify-center max-w-4xl mx-auto w-full gap-8">
            {hasResponded ? (
                    <div class="flex flex-col items-center justify-center text-center animate-in zoom-in duration-300">
                        <div class:list={[
                            "w-32 h-32 rounded-full flex items-center justify-center mb-8 shadow-[0_0_50px_rgba(0,0,0,0.5)]",
                            isCorrect ? "bg-success animate-bounce" : "bg-error animate-pulse"
                        ]}>
                            <Icon name={isCorrect ? "lucide:zap" : "lucide:circle-x"} class="w-16 h-16 text-white" />
                        </div>

                        <h2 class="text-5xl font-black uppercase italic mb-2 tracking-tighter drop-shadow-lg">
                            {isCorrect ? '¡CORRECTO!' : '¡INCORRECTO!'}
                        </h2>

                        <div class="flex gap-4 mt-8">
                            <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                                <p class="text-[10px] font-black text-zinc-500 uppercase mb-1 leading-none">Tiempo</p>
                                <p class="text-2xl font-bold">{result?.data?.time}s</p>
                            </div>
                            <div class="bg-zinc-900 p-5 rounded-3xl border border-zinc-800 min-w-[120px]">
                                <p class="text-[10px] font-black text-zinc-500 uppercase mb-1 leading-none">Puntos</p>
                                <p class="text-2xl font-black text-primary">+{result?.data?.points}</p>
                            </div>
                        </div>
                        <p class="mt-10 text-zinc-600 font-bold uppercase text-[10px] tracking-[0.3em] animate-pulse">
                            Espera la siguiente pregunta...
                        </p>
                    </div>
            ) : (
                    <div id="question-area" class="space-y-10">
                        <div class="text-center">
                            <h2 class="text-3xl md:text-5xl font-black leading-tight italic uppercase text-white drop-shadow-2xl">
                                {round?.questions?.question_text}
                            </h2>
                        </div>

                        <form id="answer-form" method="POST" action={actions.submitAnswer} class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="hidden" name="round_id" value={round_id} />
                            <input type="hidden" name="question_id" value={round?.current_question_id} />
                            <input type="hidden" name="session_id" value={gameSession?.id} />
                            <input type="hidden" name="answer_id" id="answer_id_input" />

                            {round?.questions?.answers.map((ans: any, idx: number) => (
                                    <button
                                            type="button"
                                            class="ans-btn group relative h-24 md:h-32 bg-zinc-900 border-2 border-zinc-800 rounded-[2rem] text-left overflow-hidden hover:border-primary transition-all active:scale-95 shadow-xl"
                                            onclick={`window.submitPlayerAnswer('${ans.id}')`}
                                    >
                                        <div class="flex items-center gap-5 px-8 relative z-10">
                                    <span class="w-12 h-12 rounded-2xl bg-zinc-800 group-hover:bg-primary flex items-center justify-center font-black text-2xl border border-zinc-700 transition-colors">
                                        {['A','B','C','D'][idx]}
                                    </span>
                                            <span class="font-bold text-lg md:text-xl text-zinc-200">{ans.answer_text}</span>
                                        </div>
                                        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    </button>
                            ))}
                        </form>

                        <div id="timeout-area" class="hidden flex-col items-center justify-center text-center animate-in zoom-in">
                            <div class="w-32 h-32 bg-amber-500 rounded-full flex items-center justify-center mb-8 shadow-2xl">
                                <Icon name="lucide:clock-alert" class="w-16 h-16 text-white" />
                            </div>
                            <h2 class="text-5xl font-black text-amber-500 italic uppercase">¡TIEMPO AGOTADO!</h2>
                        </div>
                    </div>
            )}
        </main>

        <footer class="mt-8 pb-10">
            <progress id="timer-bar" class="progress progress-primary w-full h-4 bg-zinc-800 shadow-inner" value="100" max="100"></progress>
        </footer>
    </div>

    <script is:inline define:vars={{ roundId: round_id, currentQ: round?.current_question_id, startTime: round?.question_started_at, limit: 30 }}>
        let isDone = false;

        window.submitPlayerAnswer = function(id) {
            if (isDone) return;
            isDone = true;
            const input = document.getElementById('answer_id_input');
            const form = document.getElementById('game-form');
            if (input && form) {
                input.value = id;
                document.querySelectorAll('.ans-btn').forEach(b => b.disabled = true);
                form.submit();
            }
        };

        async function sync() {
            if (isDone && !document.querySelector('.animate-bounce')) return;
            const { data } = await window.supabaseClient.from('event_rounds').select('current_question_id, status').eq('id', roundId).maybeSingle();
            if (data && (String(data.current_question_id) !== String(currentQ) || data.status !== 'active')) {
                isDone = true;
                window.location.href = window.location.pathname;
            }
        }
        setInterval(sync, 2500);

        const bar = document.getElementById('timer-bar');
        const txt = document.getElementById('timer-display');
        const questionUI = document.getElementById('question-area');
        const timeoutUI = document.getElementById('timeout-area');

        if (bar && startTime && !document.querySelector('.animate-bounce') && !document.querySelector('.animate-pulse')) {
            const start = new Date(startTime).getTime();
            const total = limit * 1000;

            function update() {
                const now = new Date().getTime();
                const rem = Math.max(0, total - (now - start));

                if (bar) bar.value = (rem / total) * 100;
                if (txt) txt.innerText = Math.ceil(rem / 1000).toString().padStart(2, '0');

                if (rem <= 0 && !isDone) {
                    isDone = true;
                    if (questionUI) questionUI.classList.add('hidden');
                    if (timeoutUI) {
                        timeoutUI.classList.remove('hidden');
                        timeoutUI.classList.add('flex');
                    }
                } else if (!isDone) {
                    requestAnimationFrame(update);
                }
            }
            update();
        }
    </script>
</PlayLayout>