---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import { Icon } from 'astro-icon/components';
import DeleteModal from "../../components/DeleteModal.astro";
import FormButton from "../../components/FormButton.astro";

const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");
const { data: myProfile } = await Astro.locals.supabase.from('players').select('role').eq('auth_user_id', user.id).single();
if (myProfile?.role !== 'admin') return Astro.redirect("/dashboard");

const result = Astro.getActionResult(actions.saveLifeline) || Astro.getActionResult(actions.deleteLifeline);

// Obtener la lista de comodines
const { data: lifelines } = await Astro.locals.supabase
    .from('lifelines')
    .select('*')
    .order('name', { ascending: true });
---

<DashboardLayout title="Gestión de Comodines" actionResult={result}>
    <div class="flex justify-between items-center mb-10">
        <div>
            <h2 class="text-4xl font-black italic tracking-tighter uppercase text-slate-800 flex items-center gap-3">
                <Icon name="lucide:heart-pulse" class="text-secondary" /> Comodines
            </h2>
            <p class="text-slate-500 font-medium">Ayudas disponibles para los concursantes</p>
        </div>
        <button id="btn-nuevo-comodin" class="btn btn-primary text-white font-bold px-8 shadow-lg">
            <Icon name="lucide:plus" class="w-5 h-5" /> Nuevo Comodín
        </button>
    </div>

    <!-- CUADRÍCULA DE COMODINES -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {lifelines?.map((l) => (
                <div class="card bg-white border border-base-300 shadow-sm hover:shadow-md transition-all group overflow-hidden">
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-4">
                            <div class="p-3 bg-secondary/10 rounded-2xl text-secondary">
                                <Icon name="lucide:sparkles" class="w-6 h-6" />
                            </div>
                            <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button class="btn btn-ghost btn-sm text-primary btn-edit"
                                        data-id={l.id}
                                        data-name={l.name}
                                        data-code={l.code || ''}
                                        data-desc={l.description || ''}>
                                    <Icon name="lucide:pencil" class="w-4 h-4" />
                                </button>
                                <button class="btn btn-ghost btn-sm text-error btn-delete"
                                        data-id={l.id}
                                        data-name={l.name}>
                                    <Icon name="lucide:trash-2" class="w-4 h-4" />
                                </button>
                            </div>
                        </div>
                        <h3 class="font-black text-xl text-slate-800 uppercase italic mb-2">{l.name}</h3>
                        <p class="text-sm text-slate-500 leading-relaxed">
                            {l.description || 'Sin descripción detallada.'}
                        </p>
                    </div>
                    <div class="bg-base-200/50 p-3 text-center border-t border-base-200">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">ID: #{l.id}</span>
                    </div>
                </div>
        ))}

        {lifelines?.length === 0 && (
                <div class="col-span-full py-20 text-center bg-white rounded-3xl border-2 border-dashed border-base-300">
                    <Icon name="lucide:info" class="w-12 h-12 mx-auto mb-4 opacity-10" />
                    <p class="text-slate-400 font-medium italic">No se han creado comodines todavía.</p>
                </div>
        )}
    </div>

    <!-- MODAL DE GUARDAR -->
    <dialog id="modal_lifeline" class="modal">
        <div class="modal-box max-w-md border border-base-300 p-0 overflow-visible bg-base-100">
            <div class="bg-secondary p-6 text-white">
                <h3 id="modal_title" class="font-black text-2xl italic uppercase tracking-tighter">Gestionar Comodín</h3>
            </div>

            <form method="POST" action={actions.saveLifeline} id="form-lifeline" class="p-8 space-y-4">
                <input type="hidden" name="id" id="f_id" />

                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-black text-[10px] uppercase text-slate-400">Nombre del Comodín</span>
                    </label>
                    <input name="name" id="f_name" type="text" required class="input input-bordered w-full font-bold" placeholder="Ej: 50:50 o Llamada" />
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-black text-[10px] uppercase text-slate-400">Código (para funcionalidad)</span>
                    </label>
                    <input name="code" id="f_code" type="text" class="input input-bordered w-full font-mono text-sm" placeholder="5050, saltar, llamada, publico" />
                    <p class="label-text-alt text-slate-400 mt-1">5050=eliminar 2 opciones, saltar=omitir pregunta, llamada/publico=simulación</p>
                </div>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-black text-[10px] uppercase text-slate-400">Descripción / Reglas</span>
                    </label>
                    <textarea name="description" id="f_desc" class="textarea textarea-bordered h-32 w-full" placeholder="Explica cómo funciona este comodín..."></textarea>
                </div>

                <div class="modal-action border-t border-base-300 pt-6 flex gap-3">
                    <button type="button" onclick="modal_lifeline.close()" class="btn btn-ghost px-8">Cancelar</button>
                    <FormButton class="btn-secondary text-white flex-1 font-black uppercase shadow-lg">
                        Guardar Comodín
                    </FormButton>
                </div>
            </form>
        </div>
    </dialog>

    <DeleteModal id="modal_delete" action={actions.deleteLifeline} />
</DashboardLayout>

<script>
    const modal = document.getElementById('modal_lifeline') as any;
    const form = document.getElementById('form-lifeline') as HTMLFormElement;

    if (window.unlockButtons) window.unlockButtons();

    // NUEVO
    document.getElementById('btn-nuevo-comodin')?.addEventListener('click', () => {
        form.reset();
        (document.getElementById('f_id') as HTMLInputElement).value = '';
        (document.getElementById('modal_title') as HTMLElement).innerText = 'NUEVO COMODÍN';
        modal.showModal();
    });

    // EDITAR
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', () => {
            form.reset();
            const id = btn.getAttribute('data-id');
            (document.getElementById('f_id') as HTMLInputElement).value = id || '';
            (document.getElementById('f_name') as HTMLInputElement).value = btn.getAttribute('data-name') || '';
            (document.getElementById('f_code') as HTMLInputElement).value = btn.getAttribute('data-code') || '';
            (document.getElementById('f_desc') as HTMLTextAreaElement).value = btn.getAttribute('data-desc') || '';

            (document.getElementById('modal_title') as HTMLElement).innerText = 'EDITAR COMODÍN';
            modal.showModal();
        });
    });

    // ELIMINAR
    document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const inputId = document.getElementById('modal_delete-input-id') as HTMLInputElement;
            const msg = document.getElementById('modal_delete-message');

            if (inputId) inputId.value = id || '';
            if (msg) {
                msg.textContent = '';
                msg.append('¿Estás seguro de eliminar el comodín ', Object.assign(document.createElement('strong'), { textContent: name || '' }), '?');
            }

            (document.getElementById('modal_delete') as any).showModal();
        });
    });
</script>