---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import FormButton from "@/components/FormButton.astro";

const { id } = Astro.params; // Este es el event_id
const result = Astro.getActionResult(actions.openClassroomSession);

// Si la acción fue exitosa, el servidor nos devuelve el nuevo round_id
if (result?.data?.success) {
    return Astro.redirect(`/dashboard/eventos/control/${result.data.round_id}`);
}

const { data: event } = await Astro.locals.supabase
    .from('events')
    .select('name')
    .eq('id', id)
    .single();
---

<DashboardLayout title="Preparar Salón">
    <div class="max-w-xl mx-auto mt-10">
        <div class="card bg-white border border-base-300 shadow-xl p-8 text-center">
            <h2 class="text-slate-400 font-bold uppercase text-xs mb-2">Preparando sesión para:</h2>
            <h1 class="text-3xl font-black uppercase italic mb-8">{event?.name}</h1>

            <form method="POST" action={actions.openClassroomSession} class="space-y-6">
                <input type="hidden" name="event_id" value={id} />

                <div class="form-control text-left">
                    <label class="label font-bold uppercase text-[10px] text-slate-500">Nombre de tu Grupo / Salón</label>
                    <input name="classroom_group_id" required type="text" placeholder="Ej: Sistemas 3-A" class="input input-bordered input-lg bg-base-200" />
                </div>

                <FormButton class="btn-primary btn-lg w-full text-white font-black italic uppercase">
                    Generar PIN y Abrir Sala
                </FormButton>
            </form>
        </div>
    </div>
</DashboardLayout>