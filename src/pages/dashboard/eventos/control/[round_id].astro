---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
const { round_id } = Astro.params; // Aquí ya recibimos el ID de la RONDA generada

// Obtenemos los datos de la ronda y el nombre del evento
const { data: round } = await Astro.locals.supabase
    .from('event_rounds')
    .select('*, events(name)')
    .eq('id', round_id)
    .single();
---

<DashboardLayout title="Control en Vivo">
    <div class="flex flex-col items-center justify-center text-center py-10">
        <h2 class="text-slate-400 font-bold uppercase tracking-widest">{round?.events?.name}</h2>
        <h1 class="text-5xl font-black italic uppercase text-primary mb-12">{round?.classroom_group_id}</h1>

        <!-- PIN GIGANTE -->
        <div class="bg-zinc-900 p-12 rounded-[3rem] border-4 border-primary shadow-2xl mb-12">
            <p class="text-zinc-500 font-bold uppercase tracking-widest mb-4">Código de acceso</p>
            <div class="flex gap-4">
                {round?.session_pin.split('').map(char => (
                        <span class="w-24 h-32 bg-zinc-800 flex items-center justify-center text-7xl font-black text-white rounded-2xl border border-zinc-700">
                        {char}
                    </span>
                ))}
            </div>
        </div>

        <div class="text-xl font-bold italic animate-pulse">
            Esperando a los estudiantes...
        </div>
    </div>
</DashboardLayout>
<script is:inline define:vars={{ round }}>
    async function iniciarLobby() {
        const client = window.supabaseClient;
        const grid = document.getElementById('players-grid');
        const countEl = document.getElementById('player-count');

        if (!client) {
            setTimeout(iniciarLobby, 500);
            return;
        }

        // Limpiamos canales para evitar duplicados al refrescar
        client.removeAllChannels();

        client
            .channel('lobby_channel')
            .on(
                'postgres_changes',
                { event: 'INSERT', schema: 'public', table: 'event_players' },
                async (payload) => {
                    console.log("📢 MENSAJE RECIBIDO:", payload.new);

                    // COMPARACIÓN SEGURA (Convertimos todo a String para no fallar)
                    const sameEvent = String(payload.new.event_id) === String(round.event_id);
                    const sameGroup = String(payload.new.classroom_group_id) === String(round.classroom_group_id);

                    if (sameEvent && sameGroup) {
                        console.log("✅ Estudiante validado. Buscando nombre...");

                        const { data: player } = await client
                            .from('players')
                            .select('name')
                            .eq('id', payload.new.player_id)
                            .single();

                        if (player) {
                            const idDiv = `player-${payload.new.player_id}`;
                            if (document.getElementById(idDiv)) return; // Evitar duplicados

                            const div = document.createElement('div');
                            div.id = idDiv;
                            div.className = "bg-white p-4 rounded-2xl border-2 border-primary shadow-lg animate-bounce text-center";
                            div.innerHTML = `<p class="font-black text-primary uppercase text-[10px] truncate">${player.name}</p>`;
                            grid?.appendChild(div);

                            if (countEl) {
                                let c = parseInt(countEl.innerText) || 0;
                                countEl.innerText = (c + 1).toString();
                            }
                        }
                    } else {
                        console.log("ℹ️ El registro pertenece a otro salón o evento.");
                    }
                }
            )
            .subscribe((status) => console.log("📡 ESTADO REALTIME:", status));
    }

    iniciarLobby();
</script>