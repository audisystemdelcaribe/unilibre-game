---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import { Icon } from 'astro-icon/components';
import { actions } from "astro:actions";
import FormButton from "@/components/FormButton.astro";

const { round_id } = Astro.params;
const { data: round } = await Astro.locals.supabase
    .from('event_rounds').select('*, events(*)').eq('id', round_id).single();

// 1. Cargar Ranking Final solo si el juego terminó
let rankingFinal = [];
if (round?.status === 'finished') {
    const { data } = await Astro.locals.supabase
        .from('event_players')
        .select('score, players(name)')
        .eq('event_id', round.event_id)
        .eq('classroom_group_id', round.classroom_group_id)
        .order('score', { ascending: false })
        .limit(10);
    rankingFinal = data || [];
}

// 2. Obtener texto de la pregunta actual
let qText = "Esperando...";
if (round?.current_question_id) {
    const { data: q } = await Astro.locals.supabase.from('questions').select('question_text').eq('id', round.current_question_id).single();
    qText = q?.question_text || "";
}

const result = Astro.getActionResult(actions.launchRandomQuestion) || Astro.getActionResult(actions.finishRound);
const isWaiting = round?.status === 'waiting';
const isFinished = round?.status === 'finished';
const isActive = round?.status === 'active';

---

<DashboardLayout title="Control en Vivo" actionResult={result}>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" is:inline></script>

    <div class="max-w-5xl mx-auto space-y-6">
        {isFinished ? (
            /* --- VISTA: PODIO FINAL --- */
                <div class="animate-in zoom-in duration-700 text-center py-10">
                    <Icon name="lucide:trophy" class="w-32 h-32 text-yellow-500 mx-auto mb-6 drop-shadow-2xl" />
                    <h1 class="text-5xl font-black italic uppercase text-slate-800 mb-10">Ranking Final del Salón</h1>

                    <div class="max-w-2xl mx-auto space-y-4">
                        {rankingFinal.map((res, idx) => (
                                <div class:list={[
                                    "flex items-center justify-between p-6 rounded-[2rem] border-2 shadow-lg transition-all",
                                    idx === 0 ? "bg-yellow-400 border-yellow-500 scale-105 mb-4 text-white" : "bg-white border-zinc-100 text-slate-700"
                                ]}>
                                    <div class="flex items-center gap-6">
                                        <span class="text-3xl font-black italic">{idx + 1}°</span>
                                        <span class="text-2xl font-bold uppercase tracking-tight">{res.players.name}</span>
                                    </div>
                                    <span class="text-3xl font-black font-mono">{res.score}</span>
                                </div>
                        ))}
                    </div>

                    <script is:inline>
                        // Lanzar confeti al cargar el podio
                        <script is:inline>
                            // El docente siempre lanza confeti al terminar para celebrar con el salón
                            confetti({
                            particleCount: 200,
                            spread: 100,
                            origin: { y: 0.6 }
                        });
                    </script>

                </div>
        ) : (
            /* --- LOBBY O JUEGO --- */
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="lg:col-span-2 space-y-6">
                        <div class="bg-zinc-900 text-white p-10 rounded-[3.5rem] border-b-8 border-primary shadow-2xl">
                            {isWaiting ? (
                                    <div class="text-center">
                                        <p class="text-zinc-500 font-bold uppercase text-xs mb-4">PIN DE ACCESO</p>
                                        <h2 class="text-8xl font-black tracking-widest text-white">{round?.session_pin}</h2>
                                    </div>
                            ) : (
                                    <div>
                                        <p class="text-primary font-black italic uppercase text-xs mb-4">Pregunta activa:</p>
                                        <h1 class="text-3xl font-bold italic leading-tight">{qText}</h1>
                                        <div class="mt-8 bg-white/5 p-4 rounded-2xl border border-white/10 w-fit">
                                            <p class="text-[10px] text-zinc-500 uppercase font-black">Respuestas</p>
                                            <p class="text-4xl font-black text-white" id="answered-count">0</p>
                                        </div>
                                    </div>
                            )}
                        </div>

                        <div class="flex gap-4">
                            <form method="POST" action={actions.launchRandomQuestion} class="flex-1">
                                <input type="hidden" name="round_id" value={round_id} />
                                <FormButton class="btn-primary w-full h-24 text-xl font-black shadow-xl rounded-3xl">
                                    {isWaiting ? 'INICIAR JUEGO 🚀' : 'SIGUIENTE PREGUNTA ➡️'}
                                </FormButton>
                            </form>
                            {isActive && (
                                    <form method="POST" action={actions.finishRound} onsubmit="return confirm('¿Finalizar el juego?')">
                                        <input type="hidden" name="round_id" value={round_id} />
                                        <button type="submit" class="btn btn-error h-24 px-8 text-white font-black rounded-3xl shadow-xl">TERMINAR</button>
                                    </form>
                            )}
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-[3rem] border border-base-300 shadow-sm flex flex-col h-[600px]">
                        <h3 class="font-black italic uppercase text-slate-800 border-b pb-4 mb-4 text-center">Progreso</h3>
                        <div id="responders-list" class="flex-1 overflow-y-auto space-y-2 pr-2">
                            {isWaiting && <div id="players-grid" class="grid grid-cols-2 gap-2"></div>}
                        </div>
                    </div>
                </div>
        )}
    </div>
</DashboardLayout>

<script is:inline define:vars={{ round, isWaiting, isActive }}>
    let procesados = new Set();

    async function sync() {
        const client = window.supabaseClient;
        if (!client) return;

        if (isWaiting) {
            const { data: alumnos } = await client.from('event_players').select('player_id, players(name)').eq('event_id', round.event_id).eq('classroom_group_id', round.classroom_group_id);
            alumnos?.forEach(a => {
                if (!procesados.has(a.player_id)) {
                    procesados.add(a.player_id);
                    const div = document.createElement('div');
                    div.className = "bg-blue-50 p-3 rounded-xl border border-blue-100 text-[10px] font-bold text-blue-600 text-center animate-bounce";
                    div.innerText = a.players.name;
                    document.getElementById('players-grid')?.appendChild(div);
                }
            });
        }

        if (isActive && round.current_question_id) {
            const { data: respuestas } = await client.from('game_answers').select('player_id, players(name)').eq('question_id', round.current_question_id).eq('round_id', round.id);
            if (respuestas) {
                document.getElementById('answered-count').innerText = respuestas.length;
                respuestas.forEach(r => {
                    const idDom = `resp-${r.player_id}`;
                    if (!document.getElementById(idDom)) {
                        const div = document.createElement('div');
                        div.id = idDom;
                        div.className = "p-4 bg-green-50 text-green-700 rounded-2xl text-xs font-bold flex justify-between border border-green-100 animate-in slide-in-from-right";
                        div.innerHTML = `<span>${r.players.name}</span> <span>✓</span>`;
                        document.getElementById('responders-list')?.prepend(div);
                    }
                });
            }
        }
    }

    // Recarga automática si el docente presiona botones
    setInterval(async () => {
        const { data } = await window.supabaseClient.from('event_rounds').select('current_question_id, status').eq('id', round.id).single();
        if (data && (data.current_question_id !== round.current_question_id || data.status !== round.status)) {
            window.location.reload();
        }
    }, 4000);

    sync();
    setInterval(sync, 2500);
</script>