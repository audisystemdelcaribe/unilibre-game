---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import { Icon } from 'astro-icon/components';
import DeleteModal from "../../components/DeleteModal.astro";
import FormButton from "../../components/FormButton.astro";

const user = await Astro.locals.getUser();
if (!user) return Astro.redirect("/");
const { data: myProfile } = await Astro.locals.supabase.from('players').select('role').eq('auth_user_id', user.id).single();
if (myProfile?.role !== 'admin') return Astro.redirect("/dashboard");

const resultSave = Astro.getActionResult(actions.saveSeason);
const resultDelete = Astro.getActionResult(actions.deleteSeason);

// 2. Unificar el mensaje (si es éxito o error)
const alertMessage = resultSave?.data?.success || resultDelete?.data?.success
    ? { type: 'success', text: 'Operación realizada con éxito' }
    : (resultSave?.error || resultDelete?.error)
        ? { type: 'error', text: resultSave?.error?.message || resultDelete?.error?.message || 'Ocurrió un error inesperado' }
        : null;
// 1. Obtener todas las temporadas
const { data: seasons } = await Astro.locals.supabase
    .from('seasons')
    .select('*')
    .order('year', { ascending: false })
    .order('semester', { ascending: false });

const result = Astro.getActionResult(actions.saveSeason) || Astro.getActionResult(actions.deleteSeason);
---

<DashboardLayout title="Temporadas del Juego" actionResult={result}>
    <div class="flex justify-between items-center mb-10">
        <div>
            <h2 class="text-4xl font-black italic tracking-tighter uppercase text-slate-800">Temporadas</h2>
            <p class="text-slate-500 font-medium">Periodos académicos de competición</p>
        </div>
        <button id="btn-nueva-temporada" class="btn btn-primary text-white font-bold px-8 shadow-lg">
            <Icon name="lucide:plus" class="w-5 h-5" /> Nueva Temporada
        </button>
    </div>

    <!-- TABLA DE TEMPORADAS -->
    <div class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
                <thead class="bg-base-200">
                <tr class="text-[10px] uppercase tracking-widest text-slate-500 font-bold">
                    <th class="p-6">Nombre Temporada</th>
                    <th class="p-6 text-center">Año / Semestre</th>
                    <th class="p-6 text-center">Estado</th>
                    <th class="p-6 text-right">Acciones</th>
                </tr>
                </thead>
                <tbody>
                {seasons?.map((s) => (
                        <tr class="hover:bg-base-200/50 transition-colors">
                            <td class="p-6 font-black text-slate-700 text-lg">{s.name}</td>
                            <td class="p-6 text-center font-bold">
                                <span class="badge badge-ghost font-mono">{s.year}</span>
                                <span class="badge badge-outline ml-1">{s.semester}°</span>
                            </td>
                            <td class="p-6 text-center">
                                {s.status === 'active' ? (
                                        <span class="badge badge-success text-white font-black text-[10px] gap-1 px-3">
                                        <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span> ACTIVA
                                    </span>
                                ) : (
                                        <span class="badge badge-ghost text-slate-400 font-bold text-[10px] px-3">FINALIZADA</span>
                                )}
                            </td>
                            <td class="p-6 text-right">
                                <div class="flex justify-end gap-2">
                                    <button class="btn btn-ghost btn-sm text-primary btn-edit"
                                            data-id={s.id}
                                            data-year={s.year}
                                            data-semester={s.semester}
                                            data-name={s.name}
                                            data-status={s.status}
                                    >
                                        <Icon name="lucide:pencil" class="w-4 h-4" />
                                    </button>
                                    <button class="btn btn-ghost btn-sm text-error btn-delete"
                                            data-id={s.id}
                                            data-name={s.name}>
                                        <Icon name="lucide:trash-2" class="w-4 h-4" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                ))}
                </tbody>
            </table>
        </div>
    </div>

    <!-- MODAL DE GUARDAR -->
    <dialog id="modal_season" class="modal">
        <div class="modal-box max-w-md border border-base-300 p-0 overflow-visible bg-base-100">
            <div class="bg-primary p-6 text-white">
                <h3 id="modal_title" class="font-black text-2xl italic uppercase tracking-tighter">Gestionar Temporada</h3>
                <p class="text-blue-100 text-[10px] uppercase font-bold opacity-70">Configura el ciclo de juego actual</p>
            </div>

            <form method="POST" action={actions.saveSeason} id="form-season" class="p-8 space-y-4">
                <input type="hidden" name="id" id="f_id" />

                <div class="grid grid-cols-2 gap-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Año</span></label>
                        <input name="year" id="f_year" type="number" required min="2024" max="2100" class="input input-bordered w-full font-bold" value={new Date().getFullYear()} />
                    </div>
                    <div class="form-control">
                        <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Semestre</span></label>
                        <select name="semester" id="f_semester" class="select select-bordered w-full font-bold">
                            <option value="1">1 (Ene - Jun)</option>
                            <option value="2">2 (Jul - Dic)</option>
                        </select>
                    </div>
                </div>

                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Nombre Personalizado</span></label>
                    <input name="name" id="f_name" type="text" class="input input-bordered w-full" placeholder="Ej: Gran Final 2024" />
                    <label class="label"><span class="label-text-alt italic">Si se deja vacío será "Año-Semestre"</span></label>
                </div>

                <div class="form-control">
                    <label class="label"><span class="label-text font-black text-[10px] uppercase text-slate-400">Estado</span></label>
                    <select name="status" id="f_status" class="select select-bordered w-full">
                        <option value="active">Activa (En curso)</option>
                        <option value="finished">Finalizada (Cerrada)</option>
                    </select>
                </div>

                <div class="modal-action border-t border-base-300 pt-6 flex gap-3">
                    <button type="button" onclick="modal_season.close()" class="btn btn-ghost px-8">Cancelar</button>
                    <FormButton class="btn-primary text-white flex-1 font-black uppercase shadow-lg">
                        Guardar Temporada
                    </FormButton>
                </div>
            </form>
        </div>
    </dialog>

    <DeleteModal id="modal_delete" action={actions.deleteSeason} />
</DashboardLayout>

<script>
    const modal = document.getElementById('modal_season') as any;
    const form = document.getElementById('form-season') as HTMLFormElement;

    // BOTÓN NUEVA
    document.getElementById('btn-nueva-temporada')?.addEventListener('click', () => {
        form.reset();
        (document.getElementById('f_id') as HTMLInputElement).value = '';
        (document.getElementById('modal_title') as HTMLElement).innerText = 'NUEVA TEMPORADA';
        modal.showModal();
    });

    // BOTÓN EDITAR
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const year = btn.getAttribute('data-year');
            const sem = btn.getAttribute('data-semester');
            const name = btn.getAttribute('data-name');
            const status = btn.getAttribute('data-status');

            (document.getElementById('f_id') as HTMLInputElement).value = id || '';
            (document.getElementById('f_year') as HTMLInputElement).value = year || '';
            (document.getElementById('f_semester') as HTMLSelectElement).value = sem || '1';
            (document.getElementById('f_name') as HTMLInputElement).value = name || '';
            (document.getElementById('f_status') as HTMLSelectElement).value = status || 'active';

            (document.getElementById('modal_title') as HTMLElement).innerText = 'EDITAR TEMPORADA';
            modal.showModal();
        });
    });

    // BOTÓN ELIMINAR
    document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const inputId = document.getElementById('modal_delete-input-id') as HTMLInputElement;
            const msg = document.getElementById('modal_delete-message') as HTMLElement;

            if (inputId) inputId.value = id || '';
            if (msg) {
                msg.textContent = '';
                msg.append('¿Estás seguro de eliminar la temporada ', Object.assign(document.createElement('strong'), { textContent: name || '' }), '?');
            }

            (document.getElementById('modal_delete') as any).showModal();
        });
    });
</script>