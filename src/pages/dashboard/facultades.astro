---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import FacultyModal from "../../components/FacultyModal.svelte";
import DeleteFacultyDialog from "../../components/DeleteFacultyDialog.svelte";

// Obtenemos los datos desde Supabase
const user = await Astro.locals.getUser();
const { data: faculties, error } = await Astro.locals.supabase
    .from('faculties')
    .select('*')
    .order('name', { ascending: true });

if (error) {
    console.error("Error cargando facultades:", error);
}
---

<DashboardLayout title="Facultades">
    <div class="flex justify-between items-end mb-10">
        <div>
            <h2 class="text-4xl font-black tracking-tighter uppercase italic">Facultades</h2>
            <p class="text-zinc-500 font-medium">Estructura base de la universidad</p>
        </div>
        <!-- El Modal de Svelte interactivo para crear -->
        <FacultyModal client:load />
    </div>

    <!-- Usamos HTML estándar para la tabla para evitar errores de scope en Astro -->
    <div class="bg-white border border-zinc-200 rounded-3xl overflow-hidden shadow-sm">
        <table class="w-full text-left border-collapse">
            <thead class="bg-zinc-50 border-b border-zinc-200">
            <tr>
                <th class="font-black text-zinc-400 text-[10px] uppercase p-6 tracking-widest">Nombre</th>
                <th class="font-black text-zinc-400 text-[10px] uppercase p-6 tracking-widest">Descripción</th>
                <th class="font-black text-zinc-400 text-[10px] uppercase p-6 tracking-widest text-right">Acciones</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100">
            {faculties && faculties.length > 0 ? (
                faculties.map((f) => (
                        <tr class="hover:bg-zinc-50/50 transition-colors group">
                            <td class="p-6">
                                <span class="font-bold text-zinc-800">{f.name}</span>
                            </td>
                            <td class="p-6">
                                <span class="text-zinc-500 text-sm italic">{f.description || 'Sin descripción'}</span>
                            </td>
                            <td class="p-6 text-right">
                                <div class="flex justify-end gap-2">
                                    <!-- Botón Editar -->
                                    <FacultyModal faculty={f} client:load />

                                    <!-- Botón Eliminar con Confirmación -->
                                    <DeleteFacultyDialog
                                            facultyId={f.id}
                                            facultyName={f.name}
                                            client:load
                                    />
                                </div>
                            </td>
                        </tr>
                ))
            ) : (
                    <tr>
                        <td colspan="3" class="p-20 text-center text-zinc-400">
                            <p class="text-sm font-medium">No hay facultades registradas todavía.</p>
                        </td>
                    </tr>
            )}
            </tbody>
        </table>

        <button onclick="alert('Astro puro funciona')">Probar Astro</button>

        <script>
            console.log("El JS de la página funciona");
        </script>
    </div>
</DashboardLayout>